{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MyKey": "Some key from app settings file",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=CountriesDatabase;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=False;Application Intent=ReadWrite;Multi Subnet Failover=False;Command Timeout=30"
  },
  "AllowedOrigins": [
    "http://localhost:5257",
    "https://localhost:7232",
    "https://localhost:7233",
    "http://localhost:5257",
    "https://localhost:7234",
    "http://localhost:5257",
    "https://localhost:7233",
    "http://localhost:59017"
  ],
  "EPPlus": {
    "ExcelPackage": {
      "LicenseContext": "NoneCommercial"
    }
  },
  "Serilog": {
    "MinimumLevel": "Debug",
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Hour",
          "fileSizeLimitBytes": 1048576,
          "rollOnFileSizeLimit": true
        }
      }
    ]
  },
  "Jwt": {
    "Issuer": "https://localhost:7232",
    "Audience": "https:localhost:4200", // consumer
    "EXPIRATION_MINUTES": 1,
    "Key": "secret jwt key which must be a string that is longggggggggggggggggggggg"
  },
  "RefreshToken": {
    "EXPIRATION_MINUTES":  60
  }
}
