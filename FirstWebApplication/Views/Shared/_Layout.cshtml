@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    // Get the current action and controller names using UrlHelper
    var urlHelper = ViewContext.HttpContext.RequestServices.GetService<Microsoft.AspNetCore.Mvc.Routing.IUrlHelperFactory>()?.GetUrlHelper(ViewContext);
    var currentAction = urlHelper?.ActionContext?.ActionDescriptor?.RouteValues?["action"]?.ToString();
    var currentController = urlHelper?.ActionContext?.ActionDescriptor?.RouteValues?["controller"]?.ToString();
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    @* will be substituted by value supplied in each view *@
    <title>@ViewData["appTitle"]</title>
    <style>
        /* Add a basic style for disabled buttons to make it visually clear */
        .disabled-button {
            background-color: #cccccc !important; /* Grey out */
            color: #666666 !important;
            cursor: not-allowed; /* Indicate it's not clickable */
            pointer-events: none; /* Prevent clicks */
        }
        /* Ensure hover effect is only for non-disabled buttons */
        a:not(.disabled-button):hover {
            opacity: 0.85;
        }
    </style>
</head>
<body>
    <div>
        <a href="~/" style="padding:6px 12px; background-color:cadetblue; color:white;
                            border-radius:4px; text-decoration:none; display:inline-block;">
            HOME
        </a>

        <!-- Added Buttons -->
        @* if authentication cookie is available *@
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <ul>
                <li>
                    @* predefined model *@
                    @User.Identity?.Name
                </li>
            </ul>

            <a asp-controller="Accounts" asp-action="Logout"
               style="padding:6px 12px; background-color:#28a745; color:white;
                          border-radius:4px; text-decoration:none; margin-left:10px; display:inline-block;"
               class="@(currentController == "Accounts" && currentAction == "Logout" ? "disabled-button" : "")">
                Logout
            </a>
        }
        else
        {
            <a asp-controller="Accounts" asp-action="Register"
               style="padding:6px 12px; background-color:#007bff; color:white;
                          border-radius:4px; text-decoration:none; margin-left:10px; display:inline-block;"
               class="@(currentController == "Accounts" && currentAction == "Register" ? "disabled-button" : "")">
                Register
            </a>

            <a asp-controller="Accounts" asp-action="Login"
               style="padding:6px 12px; background-color:#28a745; color:white;
                          border-radius:4px; text-decoration:none; margin-left:10px; display:inline-block;"
               class="@(currentController == "Accounts" && currentAction == "Login" ? "disabled-button" : "")">
                Sign In
            </a>
        }

        @* a special function in the layout view
            will be substituted with actual content for the actual view *@
        @RenderBody()
    </div>

    @* may be specified in other controller views *@
    <footer>
        @RenderSection("footer_section", false)
    </footer>
</body>
</html>

@RenderSection("Scripts", false)
