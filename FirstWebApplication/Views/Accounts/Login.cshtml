@model LoginDTO

@{
    ViewData["Title"] = "Login";

    var returnUrl = Context.Request.Query["ReturnUrl"].ToString();
    // If ReturnUrl points back to /Accounts/Login, ignore it to prevent recursion
    if (returnUrl?.Contains("/Accounts/Login") == true)
    {
        returnUrl = "/";
    }
}

<h2 class="mb-3">Login</h2>

<!-- Display general errors passed through ViewBag.Errors -->
@if (ViewBag.Errors != null)
{
    <div class="alert alert-danger">
        <ul>
            @foreach (string error in ViewBag?.Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@* asp-route-ReturnUrl="@returnUrl" *@
<form asp-action="Login" asp-controller="Accounts" method="post" class="needs-validation" novalidate>
    <div class="form-group mb-3">
        <label asp-for="UserName" class="form-label">Email</label>
        <input asp-for="UserName" class="form-control" placeholder="Enter your email address" />
        <span asp-validation-for="UserName" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">   
        <label asp-for="Password" class="form-label">Password</label>
        <input asp-for="Password" class="form-control" placeholder="Enter your password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary w-100">Login</button>
</form>
